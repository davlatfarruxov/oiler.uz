{
  "name": "oiler-backend",
  "version": "1.0.0",
  "description": "Oil change service automation platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "dev:old": "ts-node-dev --respawn --transpile-only --clear src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "migrate:create-tenant": "ts-node scripts/create-default-tenant.ts",
    "migrate:users": "ts-node scripts/migrate-users-to-tenant.ts",
    "migrate:core-models": "ts-node scripts/migrate-core-models.ts",
    "migrate:remaining-models": "ts-node scripts/migrate-remaining-models.ts",
    "migrate:universal-inventory": "ts-node scripts/migrate-to-universal-inventory.ts"
  },
  "keywords": [
    "oil-change",
    "service",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
